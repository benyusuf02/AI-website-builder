@model YDeveloper.Models.ContactFormViewModel

@{
    ViewData["Title"] = "İletişim - Bize Ulaşın";
    var content = ViewBag.Content as Dictionary<string, string>;
}

<link rel="stylesheet" href="~/css/homepage-ultra.css" asp-append-version="true" />

<div class="ultra-body">
    <!-- Nebula Background -->
    <div class="nebula-canvas" id="nebulaCanvas"></div>

    <!-- Contact Hero -->
    <section class="hero-ultra" style="min-height: 60vh;">
        <div class="hero-shield"></div>
        <div class="hero-tag">
            <i class="bi bi-envelope"></i> @(content?.GetValueOrDefault("contact_hero_tag", "İletişim"))
        </div>

        <h1 class="hero-title-ultra">
            @(content?.GetValueOrDefault("contact_hero_title", "Bizimle Bağlantıda Kalın"))
        </h1>
    </section>

    <!-- Contact Grid Section -->
    <div class="container pb-5">
        <div class="row g-5">
            <!-- Contact Info Sidebar -->
            <div class="col-lg-4">
                <div class="bento-item mb-4">
                    <div class="bento-icon"><i class="bi bi-geo-alt"></i></div>
                    <h3 class="bento-title">Merkez</h3>
                    <p class="bento-text">@(content?.GetValueOrDefault("contact_address", "İstanbul, Türkiye"))</p>
                </div>

                <div class="bento-item mb-4">
                    <div class="bento-icon"><i class="bi bi-headset"></i></div>
                    <h3 class="bento-title">7/24 Destek</h3>
                    <p class="bento-text">
                        @(content?.GetValueOrDefault("contact_email", "info@ydeveloper.com"))<br>
                        @(content?.GetValueOrDefault("contact_phone", "+90 (555) 123 45 67"))
                    </p>
                </div>

                <div class="bento-item">
                    <div class="bento-icon"><i class="bi bi-share"></i></div>
                    <h3 class="bento-title">Sosyal</h3>
                    <div class="d-flex gap-3 fs-3 mt-2">
                        <i class="bi bi-twitter-x"></i>
                        <i class="bi bi-linkedin"></i>
                        <i class="bi bi-instagram"></i>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="col-lg-8">
                <div class="bento-item glass-form-container">
                    <h2 class="bento-title mb-4">Mesaj Gönderin</h2>

                    <form asp-action="Contact" method="post" class="ultra-form">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-floating-nb">
                                    <input asp-for="Name" class="input-nb" placeholder="Ad Soyad" required />
                                    <label>Ad Soyad</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating-nb">
                                    <input asp-for="Email" class="input-nb" type="email" placeholder="E-posta"
                                        required />
                                    <label>E-posta</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating-nb">
                                    <input asp-for="Subject" class="input-nb" placeholder="Konu" required />
                                    <label>Konu</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating-nb">
                                    <textarea asp-for="Message" class="input-nb" style="height: 150px"
                                        placeholder="Mesajınız" required></textarea>
                                    <label>Mesajınız</label>
                                </div>
                            </div>
                            <div class="col-12 mt-4">
                                <button type="submit" class="btn-nb w-100">
                                    <span>Mesajı Gönder</span>
                                    <i class="bi bi-send"></i>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .glass-form-container {
        padding: 3rem !important;
    }

    .form-floating-nb {
        position: relative;
        margin-bottom: 1.5rem;
    }

    .input-nb {
        width: 100%;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--nb-glass-border);
        border-radius: 1rem;
        padding: 1.5rem 1rem 0.5rem;
        color: white;
        transition: 0.3s;
        outline: none;
    }

    .input-nb:focus {
        background: rgba(255, 255, 255, 0.08);
        border-color: var(--nb-primary);
        box-shadow: 0 0 15px var(--nb-primary-glow);
    }

    .form-floating-nb label {
        position: absolute;
        left: 1rem;
        top: 0.5rem;
        font-size: 0.75rem;
        color: var(--nb-accent);
        text-transform: uppercase;
        letter-spacing: 1px;
        pointer-events: none;
    }

    .text-glow {
        color: white;
        text-shadow: 0 0 20px var(--nb-primary-glow);
    }
</style>

<script>
    // Nebula Background Initialization (Shared Logic)
    function initNebula() {
        const canvas = document.getElementById('nebulaCanvas');
        if (!canvas) return;

        const layers = [
            { count: 100, class: '', sizeRange: [1, 3], speedRange: [2, 6] },
            { count: 50, class: 'layer-2', sizeRange: [3, 5], speedRange: [5, 10] },
            { count: 20, class: 'layer-3', sizeRange: [5, 8], speedRange: [10, 20] }
        ];

        layers.forEach(layer => {
            for (let i = 0; i < layer.count; i++) {
                const star = document.createElement('div');
                star.className = `nebula-star ${layer.class}`;

                const x = Math.random() * 100;
                const y = Math.random() * 100;
                const size = Math.random() * (layer.sizeRange[1] - layer.sizeRange[0]) + layer.sizeRange[0];
                const duration = Math.random() * (layer.speedRange[1] - layer.speedRange[0]) + layer.speedRange[0];

                star.style.left = `${x}%`;
                star.style.top = `${y}%`;
                star.style.width = `${size}px`;
                star.style.height = `${size}px`;
                star.style.setProperty('--duration', `${duration}s`);

                canvas.appendChild(star);
            }
        });
    }

    // Parallax Effect for Bento Items
    document.addEventListener('mousemove', (e) => {
        const bentoItems = document.querySelectorAll('.bento-item');
        const x = (window.innerWidth - e.pageX * 2) / 100;
        const y = (window.innerHeight - e.pageY * 2) / 100;

        bentoItems.forEach(item => {
            item.style.transform = `translateX(${x}px) translateY(${y}px)`;
        });
    });

    document.addEventListener('DOMContentLoaded', initNebula);
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
