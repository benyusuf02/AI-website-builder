@{
    ViewData["Title"] = "Özellikler";
}

<div class="py-5 bg-light">
    <div class="container text-center py-5">
        <h1 class="display-4 fw-bold mb-3">Tüm Özellikler</h1>
        <p class="lead text-muted mb-0">İşletmenizi büyütmek için ihtiyacınız olan her şey.</p>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4 text-center">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-3 d-inline-block mb-3">
                        <i class="bi bi-robot fs-1 text-primary"></i>
                    </div>
                    <h4 class="fw-bold">Yapay Zeka Asistanı</h4>
                    <p class="text-muted">Sadece ne istediğinizi söyleyin, AI sizin için tüm içeriği ve tasarımı
                        oluştursun.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4 text-center">
                    <div class="rounded-circle bg-success bg-opacity-10 p-3 d-inline-block mb-3">
                        <i class="bi bi-speedometer2 fs-1 text-success"></i>
                    </div>
                    <h4 class="fw-bold">Işık Hızında Performans</h4>
                    <p class="text-muted">Siteniz Google PageSpeed skorlarında zirveye oynasın. Otomatik görsel
                        optimizasyonu dahil.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4 text-center">
                    <div class="rounded-circle bg-warning bg-opacity-10 p-3 d-inline-block mb-3">
                        <i class="bi bi-shield-check fs-1 text-warning"></i>
                    </div>
                    <h4 class="fw-bold">Kurumsal Güvenlik</h4>
                    <p class="text-muted">Ücretsiz SSL sertifikası, DDoS koruması ve günlük yedekleme ile verileriniz
                        güvende.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4 text-center">
                    <div class="rounded-circle bg-info bg-opacity-10 p-3 d-inline-block mb-3">
                        <i class="bi bi-phone fs-1 text-info"></i>
                    </div>
                    <h4 class="fw-bold">%100 Mobil Uyumlu</h4>
                    <p class="text-muted">Tablet, telefon veya masaüstü. Siteniz her cihazda mükemmel görünür.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4 text-center">
                    <div class="rounded-circle bg-danger bg-opacity-10 p-3 d-inline-block mb-3">
                        <i class="bi bi-search fs-1 text-danger"></i>
                    </div>
                    <h4 class="fw-bold">SEO Dostu</h4>
                    <p class="text-muted">Arama motorlarında üst sıralara çıkmanız için gerekli tüm altyapı hazır.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4 text-center">
                    <div class="rounded-circle bg-dark bg-opacity-10 p-3 d-inline-block mb-3">
                        <i class="bi bi-globe fs-1 text-dark"></i>
                    </div>
                    <h4 class="fw-bold">Özel Alan Adı</h4>
                    <p class="text-muted">Kendi .com veya .net alan adınızı bağlayın veya ücretsiz subdomain kullanın.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bg-primary text-white py-5 mt-5">
    <div class="container text-center">
        <h2 class="fw-bold mb-4">Hemen Başlamaya Hazır Mısınız?</h2>
        <a asp-controller="Onboarding" asp-action="Step1"
            class="btn btn-light btn-lg rounded-pill px-5 fw-bold">Ücretsiz Dene</a>
    </div>
</div>
