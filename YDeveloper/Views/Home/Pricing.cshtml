@model List<YDeveloper.Models.PricingPackage>
@{
    ViewData["Title"] = "Fiyatlandırma";
}

<div class="py-5 text-center bg-light">
    <div class="container py-5">
        <h1 class="display-4 fw-bold mb-3">Şeffaf Fiyatlandırma</h1>
        <p class="lead text-muted mb-0">Gizli ücret yok. Taahhüt yok. İstediğiniz zaman iptal edin.</p>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4 justify-content-center align-items-center">
        @foreach (var pkg in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-lg h-100 position-relative"
                    style="@(pkg.Name == "Profesyonel" ? "transform: scale(1.05); z-index: 10; border: 2px solid var(--bs-primary) !important;" : "")">
                    @if (pkg.Name == "Profesyonel")
                    {
                        <div class="position-absolute top-0 start-50 translate-middle">
                            <span class="badge bg-primary rounded-pill px-3 py-2 text-uppercase fw-bold shadow-sm">En
                                Popüler</span>
                        </div>
                    }
                    <div class="card-body p-5 text-center d-flex flex-column">
                        <h3 class="fw-bold mb-2">@pkg.Name</h3>
                        <div class="mb-4">
                            <span class="display-4 fw-bold">@pkg.Price.ToString("C0")</span>
                            <span class="text-muted">/ay</span>
                        </div>
                        <p class="text-muted mb-4">@pkg.Description</p>

                        <div class="d-grid gap-3 mb-5 text-start">
                            @if (pkg.FeaturesList != null)
                            {
                                @foreach (var feature in pkg.FeaturesList)
                                {
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi bi-check-circle-fill text-success"></i>
                                        <span>@feature.Trim()</span>
                                    </div>
                                }
                            }
                        </div>

                        <div class="mt-auto">
                            <a href="/Identity/Account/Register"
                                class="btn btn-lg w-100 rounded-pill fw-bold @(pkg.Name == "Profesyonel" ? "btn-primary" : "btn-outline-dark")">
                                @(pkg.Price == 0 ? "Ücretsiz Başla" : "Hemen Başla")
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
