@* Global Loading Spinner Component *@
<div id="globalLoadingSpinner" class="loading-overlay" style="display: none;">
    <div class="spinner-container">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Yükleniyor...</span>
        </div>
        <p class="mt-3 text-white">Lütfen bekleyin...</p>
    </div>
</div>

<style>
    .loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.7);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .spinner-container {
        text-align: center;
    }
</style>

<script>
    // Global loading spinner functions
    window.showLoading = function (message = 'Lütfen bekleyin...') {
        const spinner = document.getElementById('globalLoadingSpinner');
        if (spinner) {
            spinner.querySelector('p').textContent = message;
            spinner.style.display = 'flex';
        }
    };

    window.hideLoading = function () {
        const spinner = document.getElementById('globalLoadingSpinner');
        if (spinner) {
            spinner.style.display = 'none';
        }
    };

    // Auto-hide on page load complete
    window.addEventListener('load', function () {
        hideLoading();
    });
</script>
