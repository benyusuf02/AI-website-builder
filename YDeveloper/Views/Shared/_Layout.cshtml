    <script>
        // ============ GLOBAL TOAST HELPER (SweetAlert2) ============
        window.showToast = function (type, message, title = '') {
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3500,
                timerProgressBar: true,
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer)
                    toast.addEventListener('mouseleave', Swal.resumeTimer)
                }
            });

            Toast.fire({
                icon: type, // 'success', 'error', 'warning', 'info'
                title: title || message
            });
        };

        // ============ GLOBAL LOADING SPINNER ============
        window.showLoading = function (message = 'Yükleniyor...') {
            Swal.fire({
                title: message,
                html: '<div class="spinner-border text-primary" role="status"><span class="visually-hidden">Yükleniyor...</span></div>',
                showConfirmButton: false,
                allowOutsideClick: false,
                allowEscapeKey: false
            });
        };

        window.hideLoading = function () {
            Swal.close();
        };

        // ============ SESSION TIMEOUT WARNING (25 dakika sonra uyarı) ============
        @if (SignInManager.IsSignedIn(User))
        {
            <text>
                    let sessionTimer;
                    let sessionWarned = false;

                    function resetSessionTimer() {
                        clearTimeout(sessionTimer);
                    sessionWarned = false;
                        // 25 dakika sonra uyarı göster (session timeout 30 dk)
                        sessionTimer = setTimeout(() => {
                            if (!sessionWarned) {
                        sessionWarned = true;
                    Swal.fire({
                        icon: 'warning',
                    title: 'Oturum Süresi Dolmak Üzere',
                    text: 'Oturumunuz 5 dakika içinde sonlanacak. Devam etmek için bir işlem yapın.',
                    showCancelButton: true,
                    confirmButtonText: 'Oturumu Yenile',
                    cancelButtonText: 'Kapat'
                                }).then((result) => {
                                    if (result.isConfirmed) {
                        // Ping endpoint to refresh session
                        fetch('/api/session/ping', { method: 'POST' })
                            .then(() => {
                                showToast('success', 'Oturumunuz yenilendi');
                                resetSessionTimer();
                            });
                                    }
                                });
                            }
                        }, 25 * 60 * 1000); // 25 minutes
                    }

                    // Track user activity
                    document.addEventListener('DOMContentLoaded', () => {
                        resetSessionTimer();
                        ['mousedown', 'keypress', 'scroll', 'touchstart'].forEach(event => {
                        document.addEventListener(event, resetSessionTimer, { passive: true });
                        });
                    });
            </text>
        }

            // ============ AUTO TOAST FOR TEMPDATA MESSAGES ============
            document.addEventListener('DOMContentLoaded', () => {
        @if (TempData["Success"] != null)
        {
            <text>
                            window.showToast('success', '@Html.Raw(TempData["Success"])');
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
                            window.showToast('error', '@Html.Raw(TempData["Error"])');
            </text>
        }
        @if (TempData["Warning"] != null)
        {
            <text>
                            window.showToast('warning', '@Html.Raw(TempData["Warning"])');
            </text>
        }
        @if (TempData["Info"] != null)
        {
            <text>
                            window.showToast('info', '@Html.Raw(TempData["Info"])');
            </text>
        }
        });
    </script>

    <script>
        // Notification Logic
        document.addEventListener('DOMContentLoaded', () => {
            const badge = document.getElementById('notif-badge');
            const list = document.getElementById('notif-list');

            async function fetchNotifications() {
                try {
                    // Check if user logged in by checking existence of element
                    if (!badge) return;

                    const response = await fetch('/api/notifications/unread');
                    if (response.ok) {
                        const notifications = await response.json();

                        if (notifications.length > 0) {
                            badge.textContent = notifications.length;
                            badge.style.display = 'inline-block';

                            let html = '';
                            html += '<li class="dropdown-header">Bildirimler</li>';

                            notifications.forEach(n => {
                                const date = new Date(n.createdAt).toLocaleDateString();
                                let action = n.actionUrl ? `href="${n.actionUrl}"` : 'href="#"';

                                html += `
                                    <li>
                                        <a class="dropdown-item p-3 border-bottom" ${action} onclick="markRead(${n.id})">
                                            <div class="fw-bold small">${n.title}</div>
                                            <div class="text-muted small text-wrap">${n.message}</div>
                                            <div class="text-xs text-end text-muted mt-1" style="font-size:0.75rem">${date}</div>
                                        </a>
                                    </li>
                                `;
                            });
                            list.innerHTML = html;
                        } else {
                            badge.style.display = 'none';
                            list.innerHTML = '<li class="text-center p-3 text-muted small">Yeni bildirim yok</li>';
                        }
                    }
                } catch (e) { console.error("Notif fetch error", e); }
            }

            // Poll every 60s
            fetchNotifications();
            setInterval(fetchNotifications, 60000);

            // Global function
            window.markRead = async (id) => {
                await fetch(`/api/notifications/read/${id}`, { method: 'POST' });
                // Redirect handled by href, or wait
                setTimeout(fetchNotifications, 500);
            };
        });
    </script>
