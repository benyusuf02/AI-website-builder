@model YDeveloper.Models.PricingPackage

@{
    ViewData["Title"] = "Yeni Paket Ekle";
    Layout = "_AdminLayout";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Yeni Paket Oluştur</h6>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label">Paket Adı</label>
                            <input asp-for="Name" class="form-control" placeholder="Örn: Profesyonel" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="WebsiteLimit" class="form-label">Web Sitesi Limiti</label>
                            <input asp-for="WebsiteLimit" class="form-control" />
                            <span asp-validation-for="WebsiteLimit" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label">Aylık Fiyat (TL)</label>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="YearlyPrice" class="form-label">Yıllık Fiyat (TL)</label>
                            <input asp-for="YearlyPrice" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="YearlyPrice" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Kısa Açıklama</label>
                        <input asp-for="Description" class="form-control"
                            placeholder="Örn: Küçük işletmeler için ideal" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Features" class="form-label">Özellikler (Her satıra bir özellik)</label>
                        <textarea asp-for="Features" class="form-control" rows="6"
                            placeholder="Sınırsız Disk Alanı&#10;7/24 Destek&#10;Ücretsiz SSL"></textarea>
                        <span asp-validation-for="Features" class="text-danger"></span>
                        <div class="form-text">Her özelliği yeni bir satıra yazınız.</div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsPopular">
                                <label class="form-check-label" asp-for="IsPopular">Popüler Olarak İşaretle</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                                <label class="form-check-label" asp-for="IsActive">Aktif (Satışta)</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ButtonText" class="form-label">Buton Metni</label>
                        <input asp-for="ButtonText" class="form-control" value="Hemen Başla" />
                        <span asp-validation-for="ButtonText" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="Index" class="btn btn-secondary me-md-2">İptal</a>
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
