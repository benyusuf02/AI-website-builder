@model IEnumerable<YDeveloper.Models.PricingPackage>

@{
    ViewData["Title"] = "Paket Yönetimi";
    Layout = "_AdminLayout";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Paket Yönetimi</h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-lg me-1"></i> Yeni Paket Ekle
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th>Paket Adı</th>
                        <th>Aylık Fiyat</th>
                        <th>Yıllık Fiyat</th>
                        <th>Websitesi Limiti</th>
                        <th>Durum</th>
                        <th style="width: 150px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (item.IsPopular)
                                {
                                    <span class="badge bg-warning text-dark me-2">Popüler</span>
                                }
                                <span class="fw-bold">@item.Name</span>
                            </td>
                            <td>@item.Price.ToString("C2")</td>
                            <td>@item.YearlyPrice.ToString("C2")</td>
                            <td>@item.WebsiteLimit Web Sitesi</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Pasif</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-info"
                                        title="Düzenle">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-warning" title="Durum Değiştir">
                                            <i class="bi bi-arrow-repeat"></i>
                                        </button>
                                    </form>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                        onsubmit="return confirm('Bu paketi silmek istediğinize emin misiniz?');">
                                        <button type="submit" class="btn btn-sm btn-danger" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
