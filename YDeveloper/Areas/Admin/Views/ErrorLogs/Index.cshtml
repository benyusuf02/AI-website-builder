@model List<YDeveloper.Models.AuditLog>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Hata ve İşlem Kayıtları";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">İşlem ve Hata Kayıtları (Son 50)</h1>

    <div class="card shadow-sm border-0 mt-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Tarih</th>
                            <th>Kullanıcı</th>
                            <th>Eylem</th>
                            <th>Detay</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td>@log.Timestamp.ToString("dd.MM.yyyy HH:mm:ss")</td>
                                <td>@(log.PerformerUser?.Email ?? "Sistem")</td>
                                <td><span class="badge bg-secondary">@log.Action</span></td>
                                <td class="text-break" style="max-width: 400px;">@log.Details</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
