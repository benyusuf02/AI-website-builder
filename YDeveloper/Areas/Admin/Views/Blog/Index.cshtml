@model IEnumerable<YDeveloper.Models.BlogPost>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Blog Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="h4 fw-bold mb-0">Blog Yazıları</h2>
        <p class="text-muted small">Haberler, duyurular ve makaleler.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Yeni Yazı
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Başlık</th>
                        <th>Yazar</th>
                        <th>Durum</th>
                        <th>Tarih</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                                    {
                                        <img src="@item.CoverImageUrl" class="rounded me-3"
                                            style="width: 48px; height: 32px; object-fit: cover;">
                                    }
                                    else
                                    {
                                        <div class="rounded me-3 bg-light d-flex align-items-center justify-content-center"
                                            style="width: 48px; height: 32px;">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    }
                                    <div class="fw-bold text-dark">@item.Title</div>
                                </div>
                            </td>
                            <td>@(item.Author?.FullName ?? "Bilinmiyor")</td>
                            <td>
                                @if (item.IsPublished)
                                {
                                    <span class="badge bg-success">Yayında</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Taslak</span>
                                }
                            </td>
                            <td class="text-muted small">@item.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td class="text-end pe-4">
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                    class="btn btn-sm btn-light border text-primary me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-light border text-danger"
                                        onclick="return confirm('Silmek istediğinize emin misiniz?');">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-newspaper fs-1 d-block mb-3"></i>
                                Henüz yazı eklenmemiş.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
