@model YDeveloper.Models.BlogPost
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Yazıyı Düzenle";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h4 fw-bold mb-0">Yazıyı Düzenle</h2>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Listeye Dön</a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />

                    <div class="row g-3">
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label asp-for="Title" class="form-label fw-bold">Başlık</label>
                                <input asp-for="Title" class="form-control" required />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Slug" class="form-label small text-muted">URL</label>
                                <input asp-for="Slug" class="form-control form-control-sm" />
                            </div>

                            <div class="mb-3">
                                <label asp-for="Summary" class="form-label fw-bold">Kısa Özet</label>
                                <textarea asp-for="Summary" class="form-control" rows="3"></textarea>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Content" class="form-label fw-bold">İçerik (HTML)</label>
                                <textarea asp-for="Content" class="form-control font-monospace" rows="15"></textarea>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card bg-light border-0 mb-3">
                                <div class="card-body">
                                    <h6 class="fw-bold mb-3">Yayın Ayarları</h6>

                                    <div class="form-check form-switch mb-3">
                                        <input class="form-check-input" type="checkbox" asp-for="IsPublished">
                                        <label class="form-check-label" asp-for="IsPublished">Yayında</label>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label small fw-bold">Yayın Tarihi</label>
                                        <input asp-for="PublishedAt" class="form-control" type="date" />
                                    </div>
                                    <div class="small text-muted">
                                        Oluşturulma: @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                    </div>
                                </div>
                            </div>

                            <div class="card bg-light border-0 mb-3">
                                <div class="card-body">
                                    <h6 class="fw-bold mb-3">Kapak Görseli</h6>
                                    @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                                    {
                                        <div class="mb-2">
                                            <img src="@Model.CoverImageUrl" class="img-fluid rounded border" alt="Cover"
                                                style="max-height: 150px;">
                                        </div>
                                    }
                                    <input type="file" name="coverImage" class="form-control mb-2" accept="image/*" />
                                    <div class="form-text">Değiştirmek istemiyorsanız boş bırakın.</div>
                                </div>
                            </div>

                            <div class="card bg-light border-0 mb-3">
                                <div class="card-body">
                                    <h6 class="fw-bold mb-3">SEO</h6>
                                    <div class="mb-2">
                                        <label asp-for="MetaTitle" class="form-label small">Meta Başlık</label>
                                        <input asp-for="MetaTitle" class="form-control form-control-sm" />
                                    </div>
                                    <div class="mb-2">
                                        <label asp-for="MetaDescription" class="form-label small">Meta Açıklama</label>
                                        <textarea asp-for="MetaDescription" class="form-control form-control-sm"
                                            rows="3"></textarea>
                                    </div>
                                    <div class="mb-2">
                                        <label asp-for="Tags" class="form-label small">Etiketler</label>
                                        <input asp-for="Tags" class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-3 pt-3 border-top">
                        <a asp-action="Index" class="btn btn-light">İptal</a>
                        <button type="submit" class="btn btn-primary px-4">Güncelle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
