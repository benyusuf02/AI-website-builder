@model IEnumerable<YDeveloper.Models.ContentItem>

@{
    ViewData["Title"] = "İçerik Yönetimi";
    Layout = "_AdminLayout";
    var section = ViewBag.CurrentSection ?? "all";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 style="font-size: 2rem; font-weight: 800;">İçerik Yönetimi</h1>
    <div class="btn-group">
        <a href="?section=all" class="admin-btn @(section == "all" ? "admin-btn-primary" : "admin-btn-secondary")" style="padding: 0.5rem 1rem;">Tümü</a>
        <a href="?section=homepage" class="admin-btn @(section == "homepage" ? "admin-btn-primary" : "admin-btn-secondary")" style="padding: 0.5rem 1rem;">Ana Sayfa</a>
        <a href="?section=about" class="admin-btn @(section == "about" ? "admin-btn-primary" : "admin-btn-secondary")" style="padding: 0.5rem 1rem;">Hakkımızda</a>
        <a href="?section=contact" class="admin-btn @(section == "contact" ? "admin-btn-primary" : "admin-btn-secondary")" style="padding: 0.5rem 1rem;">İletişim</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show admin-card" style="background: var(--admin-success); color: white; margin-bottom: 1.5rem;">
        <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
    </div>
}

<div class="admin-card">
    <div class="admin-table">
        <table>
            <thead>
                <tr>
                    <th>Bölüm</th>
                    <th>Anahtar</th>
                    <th>Açıklama</th>
                    <th>Değer</th>
                    <th>Güncellenme</th>
                    <th style="width: 150px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="admin-badge admin-badge-primary">@item.Section</span></td>
                        <td><code style="background: rgba(255,255,255,0.1); padding: 0.25rem 0.5rem; border-radius: 0.375rem;">@item.Key</code></td>
                        <td>@item.Description</td>
                        <td>
                            @if (item.Value.Length > 50)
                            {
                                <span>@item.Value.Substring(0, 50)...</span>
                            }
                            else
                            {
                                <span>@item.Value</span>
                            }
                        </td>
                        <td style="color: var(--admin-text-muted); font-size: 0.875rem;">
                            @item.UpdatedAt.ToString("dd.MM.yyyy HH:mm")
                        </td>
                        <td>
                            <a href="@Url.Action("Edit", new { id = item.Id })" class="admin-btn admin-btn-primary" style="padding: 0.5rem 1rem; font-size: 0.875rem;">
                                <i class="bi bi-pencil"></i> Düzenle
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    @if (!Model.Any())
    {
        <div style="text-align: center; padding: 4rem 0;">
            <i class="bi bi-file-earmark-text" style="font-size: 4rem; color: var(--admin-text-muted); opacity: 0.3;"></i>
            <p style="color: var(--admin-text-muted); margin-top: 1rem; font-size: 1.125rem;">İçerik bulunamadı</p>
        </div>
    }
</div>
