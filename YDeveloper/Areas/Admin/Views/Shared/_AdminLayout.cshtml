<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin-modern.css" />
</head>

<body class="admin-body">
    <!-- Sidebar -->
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="admin-logo">
            <i class="bi bi-lightning-charge-fill"></i> YDeveloper
        </div>

        <ul class="admin-nav">
            <li class="admin-nav-item">
                <a href="/Admin/Dashboard"
                    class="admin-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2 admin-nav-icon"></i>
                    <span>Dashboard</span>
                </a>
            </li>
            <li class="admin-nav-item">
                <a href="/Admin/Content"
                    class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Content" ? "active" : "")">
                    <i class="bi bi-file-earmark-text admin-nav-icon"></i>
                    <span>İçerik Yönetimi</span>
                </a>
            </li>
            <li class="admin-nav-item">
                <a href="/Admin/ContactMessages"
                    class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ContactMessages" ? "active" : "")">
                    <i class="bi bi-envelope admin-nav-icon"></i>
                    <span>Mesajlar</span>
                    @{
                        var context =
                        ViewContext.HttpContext.RequestServices.GetService<YDeveloper.Data.YDeveloperContext>();
                        var unreadCount = context?.ContactMessages.Count(m => !m.IsRead) ?? 0;
                    }
                    @if (unreadCount > 0)
                    {
                        <span class="admin-badge admin-badge-danger" style="margin-left: auto;">@unreadCount</span>
                    }
                </a>
            </li>
            <li class="admin-nav-item">
                <a href="/Admin/Reports"
                    class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")">
                    <i class="bi bi-graph-up admin-nav-icon"></i>
                    <span>Raporlar</span>
                </a>
            </li>
            <li class="admin-nav-item">
                <a href="/Admin/Users"
                    class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")">
                    <i class="bi bi-people admin-nav-icon"></i>
                    <span>Kullanıcılar</span>
                </a>
            </li>
            <li class="admin-nav-item">
                <a href="/Admin/Sites"
                    class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Sites" ? "active" : "")">
                    <i class="bi bi-globe admin-nav-icon"></i>
                    <span>Siteler</span>
                </a>
            </li>
                <li class="nav-item">
                    <a class="nav-link collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#legalPages" aria-expanded="false" aria-controls="legalPages">
                        <div class="sb-nav-link-icon"><i class="fas fa-file-contract"></i></div>
                        Yasal Sayfalar
                        <div class="sb-sidenav-collapse-arrow"><i class="fas fa-angle-down"></i></div>
                    </a>
                    <div class="collapse" id="legalPages" aria-labelledby="headingTwo" data-bs-parent="#sidenavAccordion">
                        <nav class="sb-sidenav-menu-nested nav accordion" id="sidenavAccordionPages">
                            <a class="nav-link" href="/Admin/Content?section=legal">Tüm Sözleşmeler</a>
                        </nav>
                    </div>
                </li>

                <li class="nav-item">
                    <a class="nav-link collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#companyPages" aria-expanded="false" aria-controls="companyPages">
                        <div class="sb-nav-link-icon"><i class="fas fa-building"></i></div>
                        Kurumsal
                        <div class="sb-sidenav-collapse-arrow"><i class="fas fa-angle-down"></i></div>
                    </a>
                    <div class="collapse" id="companyPages" aria-labelledby="headingTwo" data-bs-parent="#sidenavAccordion">
                        <nav class="sb-sidenav-menu-nested nav accordion" id="sidenavAccordionPages">
                            <a class="nav-link" href="/Admin/Content?section=about">Hakkımızda</a>
                            <a class="nav-link" href="/Admin/Content?section=contact">İletişim</a>
                        </nav>
                    </div>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Packages">
                        <div class="sb-nav-link-icon"><i class="fas fa-tags"></i></div>
                        Paketler
                    </a>
                </li>
            <li class="admin-nav-item">
                <a href="/Admin/Tickets"
                    class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tickets" ? "active" : "")">
                    <i class="bi bi-ticket admin-nav-icon"></i>
                    <span>Destek</span>
                </a>
            </li>
            <li class="admin-nav-item">
                <a href="/Admin/Settings"
                    class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")">
                    <i class="bi bi-gear admin-nav-icon"></i>
                    <span>Ayarlar</span>
                </a>
            </li>
        </ul>
    </aside>

    <!-- Main Content -->
    <main class="admin-main" id="adminMain">
        <!-- Topbar -->
        <div class="admin-topbar">
            <button class="admin-toggle-btn" id="sidebarToggle">
                <i class="bi bi-list"></i>
            </button>

            <div class="admin-search">
                <input type="search" placeholder="Ara..." />
            </div>

            <div class="admin-user-menu">
                <div class="admin-user-avatar">
                    @{
                        var userName = User.Identity?.Name ?? "Admin";
                        var initials = string.Join("", userName.Split(' ').Take(2).Select(s => s[0]));
                    }
                    @initials.ToUpper()
                </div>
                <a href="/Account/Logout" class="admin-btn admin-btn-secondary"
                    style="font-size: 0.875rem; padding: 0.5rem 1rem;">
                    <i class="bi bi-box-arrow-right"></i>
                </a>
            </div>
        </div>

        <!-- Page Content -->
        <div class="admin-content admin-animate">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show admin-card" role="alert"
                    style="background: var(--admin-success); color: white;">
                    <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show admin-card" role="alert"
                    style="background: var(--admin-error); color: white;">
                    <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js"></script>
    <script>
        // Sidebar toggle
        document.getElementById('sidebarToggle').addEventListener('click', function () {
            document.getElementById('adminSidebar').classList.toggle('collapsed');
            document.getElementById('adminMain').classList.toggle('expanded');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
