@model List<YDeveloper.Models.CannedResponse>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Hazır Cevaplar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="h4 fw-bold mb-0">Hazır Cevaplar</h2>
        <p class="text-muted small">Destek taleplerinde kullanılacak şablon yanıtlar.</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
        <i class="bi bi-plus-lg me-1"></i> Yeni Şablon
    </button>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Başlık</th>
                        <th>İçerik (Önizleme)</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@item.Title</td>
                            <td class="text-muted">
                                @(item.Content.Length > 50 ? item.Content.Substring(0, 50) + "..." : item.Content)
                            </td>
                            <td class="text-end pe-4">
                                <button type="button" class="btn btn-sm btn-light border text-primary me-1"
                                    onclick='editResponse(@item.Id, @Json.Serialize(item.Title), @Json.Serialize(item.Content))'>
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <form action="/Admin/SupportSettings/Delete" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id">
                                    <button type="submit" class="btn btn-sm btn-light border text-danger"
                                        onclick="return confirm('Silmek istediğinize emin misiniz?');">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">
                                Henüz hazır cevap şablonu eklenmemiş.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="/Admin/SupportSettings/Create" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Yeni Hazır Cevap</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Başlık (Kısa Ad)</label>
                        <input type="text" name="title" class="form-control" required
                            placeholder="Örn: Hoşgeldin Mesajı" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mesaj İçeriği</label>
                        <textarea name="content" class="form-control" rows="5" required
                            placeholder="Tam metin buraya..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Oluştur</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="/Admin/SupportSettings/Update" method="post">
                <input type="hidden" name="id" id="editId">
                <div class="modal-header">
                    <h5 class="modal-title">Düzenle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Başlık</label>
                        <input type="text" name="title" id="editTitle" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">İçerik</label>
                        <textarea name="content" id="editContent" class="form-control" rows="5" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function editResponse(id, title, content) {
        document.getElementById('editId').value = id;
        document.getElementById('editTitle').value = title;
        document.getElementById('editContent').value = content;
        new bootstrap.Modal(document.getElementById('editModal')).show();
    }
</script>
