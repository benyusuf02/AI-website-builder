@{
    ViewData["Title"] = "Erişim Raporu";
    Layout = "_AdminLayout";
}

<h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 2rem;">📊 Erişim Raporu</h1>

<!-- Stats Cards -->
<div class="admin-grid admin-grid-4" style="margin-bottom: 2rem;">
    <div class="admin-card">
        <div class="admin-card-title">Toplam Site</div>
        <div class="admin-card-value">@ViewBag.TotalSites</div>
        <div style="font-size: 0.875rem; color: var(--admin-text-muted);">Tüm zamanlar</div>
    </div>

    <div class="admin-card">
        <div class="admin-card-title">Aktif Site</div>
        <div class="admin-card-value">@ViewBag.ActiveSites</div>
        <div class="admin-card-trend up">
            <i class="bi bi-arrow-up"></i> @((ViewBag.TotalSites > 0 ? (double)ViewBag.ActiveSites / ViewBag.TotalSites * 100 : 0).ToString("F1"))% aktif
        </div>
    </div>

    <div class="admin-card">
        <div class="admin-card-title">Yeni Siteler</div>
        <div class="admin-card-value">@ViewBag.NewSitesLast30Days</div>
        <div style="font-size: 0.875rem; color: var(--admin-text-muted);">Son 30 gün</div>
    </div>

    <div class="admin-card">
        <div class="admin-card-title">Yayınlanan Sayfa</div>
        <div class="admin-card-value">@ViewBag.PublishedPages</div>
        <div style="font-size: 0.875rem; color: var(--admin-text-muted);">/ @ViewBag.TotalPages toplam</div>
    </div>
</div>

<!-- AI Insights -->
<div class="admin-card" style="margin-bottom: 2rem; background: linear-gradient(135deg, rgba(124, 58, 237, 0.1), rgba(168, 85, 247, 0.05)); border: 1px solid rgba(124, 58, 237, 0.3);">
    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
        <div style="width: 40px; height: 40px; background: var(--admin-primary); border-radius: 0.75rem; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-stars" style="font-size: 1.25rem;"></i>
        </div>
        <h3 style="font-size: 1.125rem; font-weight: 700; margin: 0;">AI İçgörüler</h3>
    </div>
    <div style="white-space: pre-wrap; line-height: 1.8; opacity: 0.95;">@ViewBag.AIInsight</div>
</div>

<!-- Chart -->
<div class="admin-card">
    <h3 style="margin-bottom: 1.5rem; font-size: 1.125rem; font-weight: 700;">Son 7 Günlük Site Oluşturma</h3>
    <canvas id="accessChart" height="300"></canvas>
</div>

@section Scripts {
    <script>
        const ctx = document.getElementById('accessChart').getContext('2d');
        const dailyStats = @Html.Raw(Json.Serialize(ViewBag.DailyStats));

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: dailyStats.map(d => new Date(d.date).toLocaleDateString('tr-TR', { day: '2-digit', month: 'short' })),
                datasets: [{
                    label: 'Yeni Siteler',
                    data: dailyStats.map(d => d.count),
                    backgroundColor: 'rgba(124, 58, 237, 0.8)',
                    borderColor: 'rgb(124, 58, 237)',
                    borderWidth: 2,
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { 
                        beginAtZero: true,
                        grid: { color: 'rgba(255,255,255,0.1)' },
                        ticks: { 
                            color: 'rgba(255,255,255,0.7)',
                            stepSize: 1
                        }
                    },
                    x: { 
                        grid: { display: false },
                        ticks: { color: 'rgba(255,255,255,0.7)' }
                    }
                }
            }
        });
    </script>
}
