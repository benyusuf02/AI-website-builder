@{
    ViewData["Title"] = "Finansal Rapor";
    Layout = "_AdminLayout";
}

<h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 2rem;">💰 Finansal Rapor</h1>

<!-- Stats Cards -->
<div class="admin-grid admin-grid-4" style="margin-bottom: 2rem;">
    <div class="admin-card">
        <div class="admin-card-title">Toplam Gelir</div>
        <div class="admin-card-value">₺@ViewBag.TotalRevenue.ToString("N0")</div>
        <div style="font-size: 0.875rem; color: var(--admin-text-muted);">Tüm zamanlar</div>
    </div>

    <div class="admin-card">
        <div class="admin-card-title">Aylık Gelir</div>
        <div class="admin-card-value">₺@ViewBag.MonthlyRevenue.ToString("N0")</div>
        <div class="admin-card-trend up">
            <i class="bi bi-arrow-up"></i> Son 30 gün
        </div>
    </div>

    <div class="admin-card">
        <div class="admin-card-title">Haftalık Gelir</div>
        <div class="admin-card-value">₺@ViewBag.WeeklyRevenue.ToString("N0")</div>
        <div style="font-size: 0.875rem; color: var(--admin-text-muted);">Son 7 gün</div>
    </div>

    <div class="admin-card">
        <div class="admin-card-title">Ort. İşlem</div>
        <div class="admin-card-value">₺@ViewBag.AvgTransaction.ToString("N0")</div>
        <div style="font-size: 0.875rem; color: var(--admin-text-muted);">@ViewBag.TransactionCount işlem</div>
    </div>
</div>

<!-- AI Insights -->
<div class="admin-card" style="margin-bottom: 2rem; background: linear-gradient(135deg, rgba(16, 185, 129, 0.1), rgba(5, 150, 105, 0.05)); border: 1px solid rgba(16, 185, 129, 0.3);">
    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
        <div style="width: 40px; height: 40px; background: var(--admin-success); border-radius: 0.75rem; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-stars" style="font-size: 1.25rem;"></i>
        </div>
        <h3 style="font-size: 1.125rem; font-weight: 700; margin: 0;">AI Finansal Analiz</h3>
    </div>
    <div style="white-space: pre-wrap; line-height: 1.8; opacity: 0.95;">@ViewBag.AIInsight</div>
</div>

<!-- Charts -->
<div class="admin-grid admin-grid-2" style="margin-bottom: 2rem;">
    <div class="admin-card">
        <h3 style="margin-bottom: 1.5rem; font-size: 1.125rem; font-weight: 700;">Son 7 Günlük Gelir Trendi</h3>
        <canvas id="revenueChart" height="250"></canvas>
    </div>

    <div class="admin-card">
        <h3 style="margin-bottom: 1.5rem; font-size: 1.125rem; font-weight: 700;">Paket Dağılımı</h3>
        <canvas id="packageChart" height="250"></canvas>
    </div>
</div>

@section Scripts {
    <script>
        // Revenue Chart
        const ctx1 = document.getElementById('revenueChart').getContext('2d');
        const dailyRevenue = @Html.Raw(Json.Serialize(ViewBag.DailyRevenue));

        new Chart(ctx1, {
            type: 'line',
            data: {
                labels: dailyRevenue.map(d => new Date(d.date).toLocaleDateString('tr-TR', { day: '2-digit', month: 'short' })),
                datasets: [{
                    label: 'Gelir (₺)',
                    data: dailyRevenue.map(d => d.amount),
                    borderColor: 'rgb(16, 185, 129)',
                    backgroundColor: 'rgba(16, 185, 129, 0.1)',
                    tension: 0.4,
                    fill: true,
                    borderWidth: 3
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { 
                        beginAtZero: true,
                        grid: { color: 'rgba(255,255,255,0.1)' },
                        ticks: { 
                            color: 'rgba(255,255,255,0.7)',
                            callback: value => '₺' + value.toLocaleString('tr-TR')
                        }
                    },
                    x: { 
                        grid: { display: false },
                        ticks: { color: 'rgba(255,255,255,0.7)' }
                    }
                }
            }
        });

        // Package Chart
        const ctx2 = document.getElementById('packageChart').getContext('2d');
        const packageStats = @Html.Raw(Json.Serialize(ViewBag.PackageStats));

        new Chart(ctx2, {
            type: 'doughnut',
            data: {
                labels: packageStats.map(p => p.package),
                datasets: [{
                    data: packageStats.map(p => p.count),
                    backgroundColor: [
                        'rgba(124, 58, 237, 0.8)',
                        'rgba(16, 185, 129, 0.8)',
                        'rgba(251, 146, 60, 0.8)',
                        'rgba(59, 130, 246, 0.8)'
                    ],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { 
                        position: 'bottom',
                        labels: { color: 'rgba(255,255,255,0.7)' }
                    }
                }
            }
        });
    </script>
}
