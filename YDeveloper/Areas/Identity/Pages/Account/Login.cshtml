@page
@model LoginModel

@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "/Views/Shared/_Layout.cshtml"; // Custom layout handling via HideContainer
    ViewData["HideContainer"] = true;
}

<div class="row g-0 min-vh-100 overflow-hidden">
    <!-- Left Side: Branding (Desktop Only) - Mirrored Layout -->
    <div
        class="col-lg-5 order-lg-2 d-none d-lg-flex flex-column justify-content-center align-items-center bg-dark text-white position-relative overflow-hidden">
        <div class="position-absolute top-0 start-0 w-100 h-100"
            style="background: linear-gradient(225deg, var(--primary) 0%, #4338ca 100%); opacity: 0.95; z-index: 1;">
        </div>

        <!-- Animated Background Elements -->
        <div class="position-absolute rounded-circle bg-white"
            style="width: 500px; height: 500px; opacity: 0.05; bottom: -150px; right: -150px;"></div>
        <div class="position-absolute border border-white opacity-10 rounded-3"
            style="width: 200px; height: 200px; top: 10%; left: 10%; transform: rotate(15deg);"></div>

        <div class="position-relative text-center px-5" style="z-index: 2;">
            <div class="display-1 mb-3 animate-fade-in">👋</div>
            <h2 class="display-6 fw-bold mb-3 animate-fade-in" style="animation-delay: 0.1s;">Hoşgeldin!</h2>
            <p class="lead text-white-50 animate-fade-in" style="animation-delay: 0.2s;">
                "İşine kaldığın yerden devam et. Yönetim panelin seni bekliyor."
            </p>

            <div class="mt-5 p-4 bg-white bg-opacity-10 rounded-4 backdrop-blur shadow-sm text-start animate-fade-in"
                style="max-width: 320px; margin: 0 auto; animation-delay: 0.3s;">
                <div class="d-flex align-items-center mb-2">
                    <i class="bi bi-shield-check text-success fs-4 me-2"></i>
                    <span class="fw-bold">Güvenli Giriş</span>
                </div>
                <small class="text-white-50 d-block">Hesabınız uçtan uca şifreleme ve 7/24 tehdit koruması
                    altındadır.</small>
            </div>
        </div>
    </div>

    <!-- Right Side: Form -->
    <div class="col-lg-7 order-lg-1 d-flex align-items-center justify-content-center bg-white py-5">
        <div class="w-100 px-4" style="max-width: 450px;">

            <div class="text-center mb-5 d-lg-none">
                <i class="bi bi-rocket-takeoff-fill text-primary fs-1"></i>
                <h3 class="fw-bold mt-2">yaptık.com</h3>
            </div>

            <div class="mb-5">
                <h2 class="fw-bold mb-2">Giriş Yap</h2>
                <p class="text-muted">E-posta ve şifrenle hesabına eriş.</p>
            </div>

            <form id="account" method="post" class="needs-validation">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4" role="alert">
                </div>

                <!-- Email -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control bg-light border-0" autocomplete="username"
                        aria-required="true" placeholder="name@example.com" style="border-radius: var(--radius-md);" />
                    <label asp-for="Input.Email" class="text-muted ps-4"><i
                            class="bi bi-envelope me-2"></i>E-posta</label>
                    <span asp-validation-for="Input.Email" class="text-danger small ms-1"></span>
                </div>

                <!-- Password -->
                <div class="form-floating mb-3 position-relative">
                    <input asp-for="Input.Password" class="form-control bg-light border-0"
                        autocomplete="current-password" aria-required="true" placeholder="password" id="loginPass"
                        style="border-radius: var(--radius-md);" />
                    <label asp-for="Input.Password" class="text-muted"><i class="bi bi-lock me-2"></i>Şifre</label>
                    <button type="button"
                        class="btn btn-link text-muted position-absolute top-50 end-0 translate-middle-y me-2 text-decoration-none">
                        <i class="bi bi-eye password-toggle"></i>
                    </button>
                    <span asp-validation-for="Input.Password" class="text-danger small ms-1"></span>
                </div>

                <!-- Remember Me & Forgot Password -->
                <div class="d-flex justify-content-between align-items-center mb-4 ps-1 pe-1">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" style="cursor: pointer;" />
                        <label class="form-check-label small text-muted user-select-none" asp-for="Input.RememberMe">
                            Beni Hatırla
                        </label>
                    </div>
                    <a id="forgot-password" asp-page="./ForgotPassword"
                        class="small fw-bold text-primary text-decoration-none">Şifreni mi unuttun?</a>
                </div>

                <input type="hidden" asp-for="Input.ReCaptchaToken" id="ReCaptchaToken" />

                <button id="login-submit" type="submit"
                    class="w-100 btn btn-primary btn-lg shadow-sm mb-4 position-relative overflow-hidden">
                    <span class="fw-bold">Giriş Yap</span>
                    <i class="bi bi-box-arrow-in-right ms-2"></i>
                </button>

                <div class="text-center">
                    <p class="text-muted small">Hesabın yok mu? <a asp-page="./Register"
                            asp-route-returnUrl="@Model.ReturnUrl"
                            class="fw-bold text-primary text-decoration-none">Hemen Kayıt Ol</a></p>
                </div>

                <!-- Divider -->
                <div class="position-relative my-4">
                    <hr class="text-muted opacity-25">
                    <span
                        class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted small text-uppercase">veya</span>
                </div>

                <!-- Social Login -->
                @{
                    if ((Model.ExternalLogins?.Count ?? 0) > 0)
                    {
                        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl"
                            method="post" class="d-grid gap-2">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                var iconClass = provider.Name.ToLower() == "google" ? "bi-google" : "bi-box-arrow-in-right";
                                var btnClass = provider.Name.ToLower() == "google" ? "btn-outline-danger" : "btn-outline-secondary";
                                <button type="submit" class="btn btn-lg @btnClass border-opacity-25 shadow-sm" name="provider"
                                    value="@provider.Name">
                                    <i class="bi @iconClass me-2"></i> @provider.DisplayName ile Giriş
                                </button>
                            }
                        </form>
                    }
                }
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://www.google.com/recaptcha/api.js?render=@ViewData["ReCaptchaSiteKey"]"></script>
    <script src="~/js/auth-ux.js" asp-append-version="true"></script>
    <script>
        // Use global ui-polish for password toggle if class 'password-toggle' is used.
        document.getElementById('account').addEventListener('submit', function (e) {
            e.preventDefault();
            const form = this;
            grecaptcha.ready(function () {
                grecaptcha.execute('@ViewData["ReCaptchaSiteKey"]', { action: 'login' }).then(function (token) {
                    document.getElementById('ReCaptchaToken').value = token;
                    form.submit();
                });
            });
        });
    </script>
}
