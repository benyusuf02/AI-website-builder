@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Şifre Değiştir";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h3 class="mb-4 fw-bold">🔑 @ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-9">
        <div class="alert alert-light border shadow-sm mb-4">
            <i class="bi bi-shield-check text-success me-2"></i> Güvenliğiniz için şifrenizi düzenli aralıklarla
            değiştirmenizi öneririz.
        </div>

        <form id="change-password-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password"
                    aria-required="true" placeholder="Eski şifreniz" />
                <label asp-for="Input.OldPassword" class="form-label">Mevcut Şifre</label>
                <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" aria-required="true"
                    placeholder="Yeni şifreniz" />
                <label asp-for="Input.NewPassword" class="form-label">Yeni Şifre</label>
                <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password"
                    aria-required="true" placeholder="Yeni şifre tekrar" />
                <label asp-for="Input.ConfirmPassword" class="form-label">Yeni Şifre (Tekrar)</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5">
                <i class="bi bi-check-circle me-2"></i> Şifreyi Güncelle
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
