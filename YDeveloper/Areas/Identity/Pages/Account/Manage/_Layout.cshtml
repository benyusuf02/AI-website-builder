@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout != null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Views/Shared/_Layout.cshtml";
    }
}

<div class="container py-5">
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-6 fw-bold">Hesap Ayarları</h1>
            <p class="text-muted">Profilinizi, güvenlik ayarlarınızı ve ödemelerinizi yönetin.</p>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        <!-- Sidebar Navigation -->
        <div class="col-lg-3 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 100px; z-index: 1;">
                <div class="card-body p-0">
                    <partial name="_ManageNav" />
                </div>
            </div>
        </div>

        <!-- Main Content Area -->
        <div class="col-lg-8 col-md-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 p-lg-5">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
