@page
@model YDeveloper.Areas.Identity.Pages.Account.Manage.BillingModel
@{
    ViewData["Title"] = "Ödeme Geçmişi";
    ViewData["ActivePage"] = "Billing";
}

<h3 class="mb-4 fw-bold">🧾 Ödeme Geçmişi</h3>

<div class="alert alert-info border-0 shadow-sm rounded-3">
    <div class="d-flex align-items-center">
        <i class="bi bi-info-circle-fill fs-4 me-3 text-info"></i>
        <div>
            <strong>Bilgi:</strong> Ödemeleriniz Iyzico güvenli ödeme altyapısı üzerinden işlenmektedir.
        </div>
    </div>
</div>

<div class="table-responsive mt-4">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th class="py-3 ps-3">Tarih</th>
                <th class="py-3">Tutar</th>
                <th class="py-3">Paket/Hizmet</th>
                <th class="py-3">Durum</th>
                <th class="py-3 pe-3 text-end">Fatura</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Transactions != null && Model.Transactions.Any())
            {
                foreach (var item in Model.Transactions)
                {
                    <tr>
                        <td class="ps-3">@item.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="fw-bold">@item.Amount.ToString("C2")</td>
                        <td>Abonelik / Hizmet</td>
                        <td>
                            @if (item.Status == "Success")
                            {
                                <span class="badge bg-success">Başarılı</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">@item.Status</span>
                            }
                        </td>
                        <td class="pe-3 text-end">
                            <button class="btn btn-sm btn-outline-secondary" disabled>İndir</button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center py-5">
                        <div class="opacity-50">
                            <i class="bi bi-receipt display-4 d-block mb-3"></i>
                            <h5>Henüz ödeme geçmişiniz bulunmuyor.</h5>
                            <p class="small">Yapılan ödemeler burada listelenecektir.</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
