@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Kişisel Veriler";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3 class="mb-4 fw-bold">💾 @ViewData["Title"]</h3>

<div class="row">
    <div class="col-md-9">
        <div class="alert alert-warning border-0 shadow-sm rounded-3">
            <h5 class="alert-heading"><i class="bi bi-exclamation-triangle-fill me-2"></i> Dikkat</h5>
            <p>
                Hesabınızdaki kişisel verileri indirebilir veya kalıcı olarak silebilirsiniz.
                Bu işlem geri alınamaz, lütfen dikkatli olun.
            </p>
        </div>

        <div class="d-grid gap-3 d-md-block mt-4">
            <form id="download-data" asp-page="DownloadPersonalData" method="post" class="d-inline">
                <button class="btn btn-outline-primary btn-lg rounded-pill px-4" type="submit">
                    <i class="bi bi-download me-2"></i> Verilerimi İndir
                </button>
            </form>

            <a id="delete" asp-page="DeletePersonalData" class="btn btn-danger btn-lg rounded-pill px-4 ms-md-3">
                <i class="bi bi-trash me-2"></i> Hesabı Sil
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
