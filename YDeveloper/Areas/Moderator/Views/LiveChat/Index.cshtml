@model IEnumerable<YDeveloper.Models.LiveChatSession>
@{
    ViewData["Title"] = "Canlı Destek Yönetimi";
    var currentStatus = ViewData["CurrentStatus"] as string ?? "active";
    var currentSearch = ViewData["CurrentSearch"] as string;
}

<div class="container-fluid py-4">
    <!-- Header & Tools -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold text-primary mb-0">
                <i class="bi bi-headset me-2"></i> Canlı Destek Talepleri
            </h2>
            <p class="text-muted small mb-0">Müşteri taleplerini anlık olarak yönetin.</p>
        </div>

        <div class="d-flex gap-2">
            <!-- Filter Tabs -->
            <div class="btn-group" role="group">
                <a href="@Url.Action("Index", new { status = "all" })"
                    class="btn btn-outline-primary @(currentStatus == "all" ? "active" : "")">Tümü</a>
                <a href="@Url.Action("Index", new { status = "active" })"
                    class="btn btn-outline-success @(currentStatus == "active" ? "active" : "")">Aktif</a>
                <a href="@Url.Action("Index", new { status = "closed" })"
                    class="btn btn-outline-secondary @(currentStatus == "closed" ? "active" : "")">Kapalı</a>
            </div>

            <!-- Search Form -->
            <form method="get" class="d-flex">
                <input type="hidden" name="status" value="@currentStatus" />
                <div class="input-group">
                    <input type="text" name="search" class="form-control" placeholder="Ara..." value="@currentSearch">
                    <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button>
                </div>
            </form>

            <a href="@Url.Action("Index", new { status = currentStatus, search = currentSearch })"
                class="btn btn-light border" title="Yenile">
                <i class="bi bi-arrow-clockwise"></i>
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Durum</th>
                            <th>Müşteri</th>
                            <th>Başlangıç</th>
                            <th>Moderatör</th>
                            <th class="text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    Kayıt bulunamadı.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr class="@(item.IsActive ? "table-active-row" : "text-muted bg-light bg-opacity-50")">
                                    <td class="ps-4">
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success rounded-pill">
                                                <i class="bi bi-circle-fill small me-1"></i> Aktif
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary rounded-pill">Kapalı</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light rounded-circle p-2 me-2 text-primary fw-bold shadow-sm"
                                                style="width:40px;height:40px;display:flex;align-items:center;justify-content:center;font-size:1.1em;">
                                                @(item.CustomerUser?.UserName?.Substring(0, 1).ToUpper() ?? "Z")
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">
                                                    @(item.CustomerUser != null ? item.CustomerUser.UserName : "Ziyaretçi")
                                                </div>
                                                <small class="text-muted" style="font-size: 0.85em;">
                                                    @if (item.CustomerUser != null)
                                                    {
                                                        @item.CustomerUser.Email
                                                    }
                                                    else
                                                    {
                                                        // Safe substring check
                                                        var id = item.CustomerUserId ?? "";
                                                        @(id.Length > 8 ? id.Substring(0, 8) + "..." : id)
                                                    }
                                                </small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <span class="fw-medium">@item.StartTime.ToString("HH:mm")</span>
                                            <span class="text-muted small">@item.StartTime.ToString("dd.MM.yyyy")</span>
                                        </div>
                                    </td>
                                    <td>
                                        @if (item.ModeratorUser != null)
                                        {
                                            <span class="badge bg-primary bg-opacity-10 text-primary">
                                                <i class="bi bi-person-fill me-1"></i> @item.ModeratorUser.UserName
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="/Moderator/LiveChat/Room/@item.Id"
                                            class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm">
                                            <i class="bi bi-chat-text-fill me-1"></i> Sohbeti Aç
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white text-muted small py-3">
            <div class="d-flex justify-content-between align-items-center">
                <span>Toplam <strong>@Model.Count()</strong> kayıt listelendi.</span>
                <span><i class="bi bi-clock-history me-1"></i> Son Güncelleme: @DateTime.Now.ToString("HH:mm:ss")</span>
            </div>
        </div>
    </div>
</div>

<style>
    .table-active-row {
        background-color: #fff;
    }

    .table-active-row:hover {
        background-color: #f8fafc;
    }
</style>

<script>
    // Optional: Auto-refresh active sessions every 30 seconds if 'Active' tab is selected
    @if (currentStatus == "active" && string.IsNullOrEmpty(currentSearch))
    {
        <text>
                setTimeout(function() {
                    window.location.reload();
            }, 30000);
        </text>
    }
</script>
