{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "YDeveloper": "Debug"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=YDeveloper;Trusted_Connection=True;MultipleActiveResultSets=true"
    },
    "Encryption": {
        "Key": "YourSecureEncryptionKey32Chars"
    },
    "Features": {
        "EnableNewDashboard": false,
        "EnableAiChatbot": false,
        "EnableAdvancedAnalytics": false,
        "MaintenanceMode": false
    },
    "RateLimiting": {
        "GlobalLimit": 100,
        "ApiLimit": 30,
        "AuthLimit": 5,
        "WindowMinutes": 1
    }
}